{
  "id": "fade-in",
  "name": "Fade In",
  "description": "A shape that fades from opacity 0 to 100 over N frames.",
  "params_schema": {
    "type": "object",
    "required": ["duration_frames"],
    "properties": {
      "duration_frames": { "type": "integer", "minimum": 1, "maximum": 600, "default": 30 },
      "size":            { "type": "integer", "minimum": 16, "maximum": 1024, "default": 200 },
      "color":           { "type": "array", "minItems": 3, "maxItems": 4, "items": { "type": "number", "minimum": 0, "maximum": 1 } },
      "easing":          { "type": "string", "enum": ["linear", "easeInOut", "easeOut", "easeIn"], "default": "easeOut" }
    }
  },
  "body": {
    "v": "5.12.0",
    "fr": 30,
    "ip": 0,
    "op": "{{duration_frames}}",
    "w": "{{size}}",
    "h": "{{size}}",
    "nm": "fade-in",
    "ddd": 0,
    "assets": [],
    "layers": [
      {
        "ddd": 0,
        "ind": 1,
        "ty": 4,
        "nm": "main",
        "sr": 1,
        "ks": {
          "o": {
            "a": 1,
            "k": [
              {
                "t": 0,
                "s": [0],
                "i": { "x": [0.25], "y": [1] },
                "o": { "x": [0.25], "y": [0] }
              },
              { "t": "{{duration_frames}}", "s": [100] }
            ]
          },
          "r": { "a": 0, "k": 0 },
          "p": { "a": 0, "k": [100, 100, 0] },
          "a": { "a": 0, "k": [0, 0, 0] },
          "s": { "a": 0, "k": [100, 100, 100] }
        },
        "ao": 0,
        "shapes": [
          {
            "ty": "el",
            "p": { "a": 0, "k": [0, 0] },
            "s": { "a": 0, "k": [120, 120] },
            "nm": "Ellipse"
          },
          {
            "ty": "fl",
            "o": { "a": 0, "k": 100 },
            "c": { "a": 0, "k": "{{color}}" },
            "nm": "Fill"
          },
          {
            "ty": "tr",
            "p": { "a": 0, "k": [0, 0] },
            "a": { "a": 0, "k": [0, 0] },
            "s": { "a": 0, "k": [100, 100] },
            "r": { "a": 0, "k": 0 },
            "o": { "a": 0, "k": 100 },
            "nm": "Transform"
          }
        ],
        "ip": 0,
        "op": "{{duration_frames}}",
        "st": 0,
        "bm": 0
      }
    ],
    "markers": [],
    "meta": {
      "g": "open-lottie-ui",
      "a": "open-lottie-ui template",
      "k": "fade-in template",
      "easing": "{{easing}}"
    }
  }
}

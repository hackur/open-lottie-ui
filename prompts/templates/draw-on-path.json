{
  "id": "draw-on-path",
  "name": "Draw on Path",
  "description": "An SVG-like path drawn on via animated trim (tm) from 0 → 100, then held or looped.",
  "params_schema": {
    "type": "object",
    "required": ["path_d", "duration_frames"],
    "properties": {
      "path_d":          { "type": "string", "description": "SVG path-like string. The tool converts to Lottie bezier shape data." },
      "duration_frames": { "type": "integer", "minimum": 6, "maximum": 600, "default": 60 },
      "stroke_width":    { "type": "number", "minimum": 0.5, "maximum": 64, "default": 4 },
      "stroke_color":    { "type": "array", "minItems": 3, "maxItems": 4, "items": { "type": "number", "minimum": 0, "maximum": 1 } },
      "size":            { "type": "integer", "minimum": 16, "maximum": 1024, "default": 200 },
      "loop":            { "type": "boolean", "default": false }
    }
  },
  "body": {
    "v": "5.12.0",
    "fr": 30,
    "ip": 0,
    "op": "{{duration_frames}}",
    "w": "{{size}}",
    "h": "{{size}}",
    "nm": "draw-on-path",
    "ddd": 0,
    "assets": [],
    "layers": [
      {
        "ddd": 0,
        "ind": 1,
        "ty": 4,
        "nm": "main",
        "sr": 1,
        "ks": {
          "o": { "a": 0, "k": 100 },
          "r": { "a": 0, "k": 0 },
          "p": { "a": 0, "k": [100, 100, 0] },
          "a": { "a": 0, "k": [0, 0, 0] },
          "s": { "a": 0, "k": [100, 100, 100] }
        },
        "ao": 0,
        "shapes": [
          {
            "ty": "el",
            "p": { "a": 0, "k": [0, 0] },
            "s": { "a": 0, "k": [120, 120] },
            "nm": "Path"
          },
          {
            "ty": "st",
            "o": { "a": 0, "k": 100 },
            "c": { "a": 0, "k": "{{stroke_color}}" },
            "w": { "a": 0, "k": "{{stroke_width}}" },
            "lc": 2,
            "lj": 2,
            "ml": 4,
            "nm": "Stroke"
          },
          {
            "ty": "tm",
            "s": { "a": 0, "k": 0 },
            "e": {
              "a": 1,
              "k": [
                {
                  "t": 0,
                  "s": [0],
                  "i": { "x": [0.42], "y": [1] },
                  "o": { "x": [0.58], "y": [0] }
                },
                { "t": "{{duration_frames}}", "s": [100] }
              ]
            },
            "o": { "a": 0, "k": 0 },
            "m": 1,
            "nm": "Trim Paths"
          },
          {
            "ty": "tr",
            "p": { "a": 0, "k": [0, 0] },
            "a": { "a": 0, "k": [0, 0] },
            "s": { "a": 0, "k": [100, 100] },
            "r": { "a": 0, "k": 0 },
            "o": { "a": 0, "k": 100 },
            "nm": "Transform"
          }
        ],
        "ip": 0,
        "op": "{{duration_frames}}",
        "st": 0,
        "bm": 0
      }
    ],
    "markers": [],
    "meta": {
      "g": "open-lottie-ui",
      "a": "open-lottie-ui template",
      "k": "draw-on-path template",
      "path_d": "{{path_d}}",
      "loop": "{{loop}}"
    }
  }
}

{
  "id": "typing-dots",
  "name": "Typing Dots",
  "description": "A chat indicator: 3 dots in a row at canvas center, each scaling 80 → 120 → 80 with phase offsets so they ripple. Loops seamlessly. Authored for dot_count=3; the dot_count param is metadata only in M1.",
  "params_schema": {
    "type": "object",
    "required": ["duration_frames"],
    "properties": {
      "duration_frames": { "type": "integer", "minimum": 12, "maximum": 600, "default": 60 },
      "size":            { "type": "integer", "minimum": 16, "maximum": 1024, "default": 200 },
      "color":           { "type": "array", "minItems": 3, "maxItems": 4, "items": { "type": "number", "minimum": 0, "maximum": 1 } },
      "dot_count":       { "type": "integer", "minimum": 2, "maximum": 5, "default": 3 }
    }
  },
  "body": {
    "v": "5.12.0",
    "fr": 30,
    "ip": 0,
    "op": "{{duration_frames}}",
    "w": "{{size}}",
    "h": "{{size}}",
    "nm": "typing-dots",
    "ddd": 0,
    "assets": [],
    "layers": [
      {
        "ddd": 0,
        "ind": 1,
        "ty": 4,
        "nm": "dot-left",
        "sr": 1,
        "ks": {
          "o": { "a": 0, "k": 100 },
          "r": { "a": 0, "k": 0 },
          "p": { "a": 0, "k": [70, 100, 0] },
          "a": { "a": 0, "k": [0, 0, 0] },
          "s": {
            "a": 1,
            "k": [
              { "t": 0,  "s": [80, 80, 100],   "i": { "x": [0.4, 0.4, 0.4], "y": [1, 1, 1] }, "o": { "x": [0.6, 0.6, 0.6], "y": [0, 0, 0] } },
              { "t": 15, "s": [120, 120, 100], "i": { "x": [0.4, 0.4, 0.4], "y": [1, 1, 1] }, "o": { "x": [0.6, 0.6, 0.6], "y": [0, 0, 0] } },
              { "t": 30, "s": [80, 80, 100],   "i": { "x": [0.4, 0.4, 0.4], "y": [1, 1, 1] }, "o": { "x": [0.6, 0.6, 0.6], "y": [0, 0, 0] } },
              { "t": "{{duration_frames}}", "s": [80, 80, 100] }
            ]
          }
        },
        "ao": 0,
        "shapes": [
          { "ty": "el", "p": { "a": 0, "k": [0, 0] }, "s": { "a": 0, "k": [22, 22] }, "nm": "Ellipse" },
          { "ty": "fl", "o": { "a": 0, "k": 100 }, "c": { "a": 0, "k": "{{color}}" }, "nm": "Fill" },
          { "ty": "tr", "p": { "a": 0, "k": [0, 0] }, "a": { "a": 0, "k": [0, 0] }, "s": { "a": 0, "k": [100, 100] }, "r": { "a": 0, "k": 0 }, "o": { "a": 0, "k": 100 }, "nm": "Transform" }
        ],
        "ip": 0,
        "op": "{{duration_frames}}",
        "st": 0,
        "bm": 0
      },
      {
        "ddd": 0,
        "ind": 2,
        "ty": 4,
        "nm": "dot-mid",
        "sr": 1,
        "ks": {
          "o": { "a": 0, "k": 100 },
          "r": { "a": 0, "k": 0 },
          "p": { "a": 0, "k": [100, 100, 0] },
          "a": { "a": 0, "k": [0, 0, 0] },
          "s": {
            "a": 1,
            "k": [
              { "t": 0,  "s": [80, 80, 100],   "i": { "x": [0.4, 0.4, 0.4], "y": [1, 1, 1] }, "o": { "x": [0.6, 0.6, 0.6], "y": [0, 0, 0] } },
              { "t": 8,  "s": [80, 80, 100],   "i": { "x": [0.4, 0.4, 0.4], "y": [1, 1, 1] }, "o": { "x": [0.6, 0.6, 0.6], "y": [0, 0, 0] } },
              { "t": 23, "s": [120, 120, 100], "i": { "x": [0.4, 0.4, 0.4], "y": [1, 1, 1] }, "o": { "x": [0.6, 0.6, 0.6], "y": [0, 0, 0] } },
              { "t": 38, "s": [80, 80, 100],   "i": { "x": [0.4, 0.4, 0.4], "y": [1, 1, 1] }, "o": { "x": [0.6, 0.6, 0.6], "y": [0, 0, 0] } },
              { "t": "{{duration_frames}}", "s": [80, 80, 100] }
            ]
          }
        },
        "ao": 0,
        "shapes": [
          { "ty": "el", "p": { "a": 0, "k": [0, 0] }, "s": { "a": 0, "k": [22, 22] }, "nm": "Ellipse" },
          { "ty": "fl", "o": { "a": 0, "k": 100 }, "c": { "a": 0, "k": "{{color}}" }, "nm": "Fill" },
          { "ty": "tr", "p": { "a": 0, "k": [0, 0] }, "a": { "a": 0, "k": [0, 0] }, "s": { "a": 0, "k": [100, 100] }, "r": { "a": 0, "k": 0 }, "o": { "a": 0, "k": 100 }, "nm": "Transform" }
        ],
        "ip": 0,
        "op": "{{duration_frames}}",
        "st": 0,
        "bm": 0
      },
      {
        "ddd": 0,
        "ind": 3,
        "ty": 4,
        "nm": "dot-right",
        "sr": 1,
        "ks": {
          "o": { "a": 0, "k": 100 },
          "r": { "a": 0, "k": 0 },
          "p": { "a": 0, "k": [130, 100, 0] },
          "a": { "a": 0, "k": [0, 0, 0] },
          "s": {
            "a": 1,
            "k": [
              { "t": 0,  "s": [80, 80, 100],   "i": { "x": [0.4, 0.4, 0.4], "y": [1, 1, 1] }, "o": { "x": [0.6, 0.6, 0.6], "y": [0, 0, 0] } },
              { "t": 16, "s": [80, 80, 100],   "i": { "x": [0.4, 0.4, 0.4], "y": [1, 1, 1] }, "o": { "x": [0.6, 0.6, 0.6], "y": [0, 0, 0] } },
              { "t": 31, "s": [120, 120, 100], "i": { "x": [0.4, 0.4, 0.4], "y": [1, 1, 1] }, "o": { "x": [0.6, 0.6, 0.6], "y": [0, 0, 0] } },
              { "t": 46, "s": [80, 80, 100],   "i": { "x": [0.4, 0.4, 0.4], "y": [1, 1, 1] }, "o": { "x": [0.6, 0.6, 0.6], "y": [0, 0, 0] } },
              { "t": "{{duration_frames}}", "s": [80, 80, 100] }
            ]
          }
        },
        "ao": 0,
        "shapes": [
          { "ty": "el", "p": { "a": 0, "k": [0, 0] }, "s": { "a": 0, "k": [22, 22] }, "nm": "Ellipse" },
          { "ty": "fl", "o": { "a": 0, "k": 100 }, "c": { "a": 0, "k": "{{color}}" }, "nm": "Fill" },
          { "ty": "tr", "p": { "a": 0, "k": [0, 0] }, "a": { "a": 0, "k": [0, 0] }, "s": { "a": 0, "k": [100, 100] }, "r": { "a": 0, "k": 0 }, "o": { "a": 0, "k": 100 }, "nm": "Transform" }
        ],
        "ip": 0,
        "op": "{{duration_frames}}",
        "st": 0,
        "bm": 0
      }
    ],
    "markers": [],
    "meta": {
      "g": "open-lottie-ui",
      "a": "open-lottie-ui template",
      "k": "typing-dots template",
      "dot_count": "{{dot_count}}"
    }
  }
}

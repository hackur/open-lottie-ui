{
  "id": "slide-in",
  "name": "Slide In",
  "description": "A shape that slides from off-canvas to a target position with ease-out.",
  "params_schema": {
    "type": "object",
    "required": ["from", "to", "duration_frames"],
    "properties": {
      "from":            { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number" }, "description": "Start [x, y] in canvas coords." },
      "to":              { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number" }, "description": "End [x, y] in canvas coords." },
      "duration_frames": { "type": "integer", "minimum": 6, "maximum": 600, "default": 30 },
      "size":            { "type": "integer", "minimum": 16, "maximum": 1024, "default": 200 },
      "shape":           { "type": "string", "enum": ["circle", "rect", "rounded-rect"], "default": "circle" },
      "color":           { "type": "array", "minItems": 3, "maxItems": 4, "items": { "type": "number", "minimum": 0, "maximum": 1 } },
      "easing":          { "type": "string", "enum": ["linear", "easeOut", "easeOutQuad", "easeOutCubic"], "default": "easeOutCubic" }
    }
  },
  "body": {
    "v": "5.12.0",
    "fr": 30,
    "ip": 0,
    "op": "{{duration_frames}}",
    "w": "{{size}}",
    "h": "{{size}}",
    "nm": "slide-in",
    "ddd": 0,
    "assets": [],
    "layers": [
      {
        "ddd": 0,
        "ind": 1,
        "ty": 4,
        "nm": "main",
        "sr": 1,
        "ks": {
          "o": { "a": 0, "k": 100 },
          "r": { "a": 0, "k": 0 },
          "p": {
            "a": 1,
            "k": [
              {
                "t": 0,
                "s": ["{{from.0}}", "{{from.1}}", 0],
                "i": { "x": [0.16, 0.16, 0.16], "y": [1, 1, 1] },
                "o": { "x": [0.33, 0.33, 0.33], "y": [0, 0, 0] }
              },
              {
                "t": "{{duration_frames}}",
                "s": ["{{to.0}}", "{{to.1}}", 0]
              }
            ]
          },
          "a": { "a": 0, "k": [0, 0, 0] },
          "s": { "a": 0, "k": [100, 100, 100] }
        },
        "ao": 0,
        "shapes": [
          {
            "ty": "rc",
            "p": { "a": 0, "k": [0, 0] },
            "s": { "a": 0, "k": [80, 80] },
            "r": { "a": 0, "k": 8 },
            "nm": "Rectangle"
          },
          {
            "ty": "fl",
            "o": { "a": 0, "k": 100 },
            "c": { "a": 0, "k": "{{color}}" },
            "nm": "Fill"
          },
          {
            "ty": "tr",
            "p": { "a": 0, "k": [0, 0] },
            "a": { "a": 0, "k": [0, 0] },
            "s": { "a": 0, "k": [100, 100] },
            "r": { "a": 0, "k": 0 },
            "o": { "a": 0, "k": 100 },
            "nm": "Transform"
          }
        ],
        "ip": 0,
        "op": "{{duration_frames}}",
        "st": 0,
        "bm": 0
      }
    ],
    "markers": [],
    "meta": {
      "g": "open-lottie-ui",
      "a": "open-lottie-ui template",
      "k": "slide-in template",
      "shape": "{{shape}}",
      "easing": "{{easing}}"
    }
  }
}

{
  "id": "color-pulse",
  "name": "Color Pulse",
  "description": "A filled circle whose color cross-fades between two colors, looped seamlessly.",
  "params_schema": {
    "type": "object",
    "required": ["color_a", "color_b", "duration_frames"],
    "properties": {
      "color_a": {
        "type": "array",
        "minItems": 3,
        "maxItems": 4,
        "items": { "type": "number", "minimum": 0, "maximum": 1 },
        "description": "Start color, normalized RGB or RGBA."
      },
      "color_b": {
        "type": "array",
        "minItems": 3,
        "maxItems": 4,
        "items": { "type": "number", "minimum": 0, "maximum": 1 },
        "description": "End color, normalized RGB or RGBA."
      },
      "duration_frames": {
        "type": "integer",
        "minimum": 6,
        "maximum": 600,
        "default": 60
      },
      "size": {
        "type": "integer",
        "minimum": 16,
        "maximum": 1024,
        "default": 200
      }
    }
  },
  "body": {
    "v": "5.12.0",
    "fr": 30,
    "ip": 0,
    "op": "{{duration_frames}}",
    "w": "{{size}}",
    "h": "{{size}}",
    "nm": "color-pulse",
    "ddd": 0,
    "assets": [],
    "layers": [
      {
        "ddd": 0,
        "ind": 1,
        "ty": 4,
        "nm": "main",
        "sr": 1,
        "ks": {
          "o": { "a": 0, "k": 100 },
          "r": { "a": 0, "k": 0 },
          "p": { "a": 0, "k": [100, 100, 0] },
          "a": { "a": 0, "k": [0, 0, 0] },
          "s": { "a": 0, "k": [100, 100, 100] }
        },
        "ao": 0,
        "shapes": [
          {
            "ty": "el",
            "p": { "a": 0, "k": [0, 0] },
            "s": { "a": 0, "k": [120, 120] },
            "nm": "Ellipse"
          },
          {
            "ty": "fl",
            "o": { "a": 0, "k": 100 },
            "c": {
              "a": 1,
              "k": [
                {
                  "t": 0,
                  "s": "{{color_a}}",
                  "i": { "x": [0.42], "y": [1] },
                  "o": { "x": [0.58], "y": [0] }
                },
                {
                  "t": "{{duration_frames}}",
                  "s": "{{color_b}}"
                }
              ]
            },
            "nm": "Fill"
          },
          {
            "ty": "tr",
            "p": { "a": 0, "k": [0, 0] },
            "a": { "a": 0, "k": [0, 0] },
            "s": { "a": 0, "k": [100, 100] },
            "r": { "a": 0, "k": 0 },
            "o": { "a": 0, "k": 100 },
            "nm": "Transform"
          }
        ],
        "ip": 0,
        "op": "{{duration_frames}}",
        "st": 0,
        "bm": 0
      }
    ],
    "markers": [],
    "meta": {
      "g": "open-lottie-ui",
      "a": "open-lottie-ui template",
      "k": "color-pulse template"
    }
  }
}

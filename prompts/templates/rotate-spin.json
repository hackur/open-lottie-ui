{
  "id": "rotate-spin",
  "name": "Rotate Spin",
  "description": "A 3/4-arc circular loader that rotates 0° → 360° linearly over the duration. Seamlessly loops.",
  "params_schema": {
    "type": "object",
    "required": ["duration_frames"],
    "properties": {
      "duration_frames": { "type": "integer", "minimum": 12, "maximum": 600, "default": 60 },
      "size":            { "type": "integer", "minimum": 16, "maximum": 1024, "default": 200 },
      "color":           { "type": "array", "minItems": 3, "maxItems": 4, "items": { "type": "number", "minimum": 0, "maximum": 1 } },
      "stroke_width":    { "type": "number", "minimum": 1, "maximum": 64, "default": 8 },
      "clockwise":       { "type": "boolean", "default": true }
    }
  },
  "body": {
    "v": "5.12.0",
    "fr": 30,
    "ip": 0,
    "op": "{{duration_frames}}",
    "w": "{{size}}",
    "h": "{{size}}",
    "nm": "rotate-spin",
    "ddd": 0,
    "assets": [],
    "layers": [
      {
        "ddd": 0,
        "ind": 1,
        "ty": 4,
        "nm": "arc",
        "sr": 1,
        "ks": {
          "o": { "a": 0, "k": 100 },
          "r": {
            "a": 1,
            "k": [
              {
                "t": 0,
                "s": [0],
                "i": { "x": [0.5], "y": [0.5] },
                "o": { "x": [0.5], "y": [0.5] }
              },
              { "t": "{{duration_frames}}", "s": [360] }
            ]
          },
          "p": { "a": 0, "k": [100, 100, 0] },
          "a": { "a": 0, "k": [0, 0, 0] },
          "s": { "a": 0, "k": [100, 100, 100] }
        },
        "ao": 0,
        "shapes": [
          {
            "ty": "el",
            "p": { "a": 0, "k": [0, 0] },
            "s": { "a": 0, "k": [140, 140] },
            "nm": "Ellipse"
          },
          {
            "ty": "tm",
            "s": { "a": 0, "k": 0 },
            "e": { "a": 0, "k": 75 },
            "o": { "a": 0, "k": 0 },
            "m": 1,
            "nm": "Trim Paths"
          },
          {
            "ty": "st",
            "c": { "a": 0, "k": "{{color}}" },
            "o": { "a": 0, "k": 100 },
            "w": { "a": 0, "k": "{{stroke_width}}" },
            "lc": 2,
            "lj": 2,
            "nm": "Stroke"
          },
          {
            "ty": "tr",
            "p": { "a": 0, "k": [0, 0] },
            "a": { "a": 0, "k": [0, 0] },
            "s": { "a": 0, "k": [100, 100] },
            "r": { "a": 0, "k": 0 },
            "o": { "a": 0, "k": 100 },
            "nm": "Transform"
          }
        ],
        "ip": 0,
        "op": "{{duration_frames}}",
        "st": 0,
        "bm": 0
      }
    ],
    "markers": [],
    "meta": {
      "g": "open-lottie-ui",
      "a": "open-lottie-ui template",
      "k": "rotate-spin template",
      "clockwise": "{{clockwise}}"
    }
  }
}

{
  "id": "scale-bounce",
  "name": "Scale Bounce",
  "description": "A shape that scales 100 → 110 → 100 with overshoot, looped.",
  "params_schema": {
    "type": "object",
    "required": ["duration_frames"],
    "properties": {
      "duration_frames": { "type": "integer", "minimum": 12, "maximum": 600, "default": 48 },
      "overshoot_pct":   { "type": "number", "minimum": 100, "maximum": 200, "default": 110 },
      "size":            { "type": "integer", "minimum": 16, "maximum": 1024, "default": 200 },
      "color":           { "type": "array", "minItems": 3, "maxItems": 4, "items": { "type": "number", "minimum": 0, "maximum": 1 } }
    }
  },
  "body": {
    "v": "5.12.0",
    "fr": 30,
    "ip": 0,
    "op": "{{duration_frames}}",
    "w": "{{size}}",
    "h": "{{size}}",
    "nm": "scale-bounce",
    "ddd": 0,
    "assets": [],
    "layers": [
      {
        "ddd": 0,
        "ind": 1,
        "ty": 4,
        "nm": "main",
        "sr": 1,
        "ks": {
          "o": { "a": 0, "k": 100 },
          "r": { "a": 0, "k": 0 },
          "p": { "a": 0, "k": [100, 100, 0] },
          "a": { "a": 0, "k": [0, 0, 0] },
          "s": {
            "a": 1,
            "k": [
              {
                "t": 0,
                "s": [100, 100, 100],
                "i": { "x": [0.4, 0.4, 0.4], "y": [1, 1, 1] },
                "o": { "x": [0.6, 0.6, 0.6], "y": [0, 0, 0] }
              },
              {
                "t": "{{duration_frames}}",
                "s": ["{{overshoot_pct}}", "{{overshoot_pct}}", 100],
                "i": { "x": [0.4, 0.4, 0.4], "y": [1, 1, 1] },
                "o": { "x": [0.6, 0.6, 0.6], "y": [0, 0, 0] }
              }
            ]
          }
        },
        "ao": 0,
        "shapes": [
          {
            "ty": "rc",
            "p": { "a": 0, "k": [0, 0] },
            "s": { "a": 0, "k": [120, 120] },
            "r": { "a": 0, "k": 8 },
            "nm": "Rectangle"
          },
          {
            "ty": "fl",
            "o": { "a": 0, "k": 100 },
            "c": { "a": 0, "k": "{{color}}" },
            "nm": "Fill"
          },
          {
            "ty": "tr",
            "p": { "a": 0, "k": [0, 0] },
            "a": { "a": 0, "k": [0, 0] },
            "s": { "a": 0, "k": [100, 100] },
            "r": { "a": 0, "k": 0 },
            "o": { "a": 0, "k": 100 },
            "nm": "Transform"
          }
        ],
        "ip": 0,
        "op": "{{duration_frames}}",
        "st": 0,
        "bm": 0
      }
    ],
    "markers": [],
    "meta": {
      "g": "open-lottie-ui",
      "a": "open-lottie-ui template",
      "k": "scale-bounce template"
    }
  }
}
